void main() {
    String texto;
    int opcion;
    do {

        IO.println("==============");
        IO.println(" CALCULADORA ");
        IO.println("==============");
        IO.println("1. Sumar");
        IO.println("2. Restar");
        IO.println("3. Multiplicar");
        IO.println("4. Dividir");
        IO.println("5. Salir");

        texto = IO.readln("Seleccione una opción: ");
        opcion = Integer.parseInt(texto);

        switch(opcion){

            case 1:
                texto = IO.readln("Ingrese el primer valor: ");
                int num1 = Integer.parseInt(texto);
                texto = IO.readln("Ingrese el segundo valor: ");
                int num2 = Integer.parseInt(texto);
                int suma = num1 + num2;
                IO.println("Resultado = " + suma);
                break;

            case 2:
                texto = IO.readln("Ingrese el primer valor: ");
                num1 = Integer.parseInt(texto);
                texto = IO.readln("Ingrese el segundo valor: ");
                num2 = Integer.parseInt(texto);
                int resta = num1 - num2;
                IO.println("Resultado = " + resta);
                break;

            case 3:

                texto = IO.readln("Ingrese el primer valor: ");
                num1 = Integer.parseInt(texto);
                texto = IO.readln("Ingrese el segundo valor: ");
                num2 = Integer.parseInt(texto);
                int multiplicacion = num1 * num2;
                IO.println("Resultado = " + multiplicacion);
                break;
            case 4:

                texto = IO.readln("Ingrese el primer valor: ");
                num1 = Integer.parseInt(texto);
                texto = IO.readln("Ingrese el segundo valor: ");
                num2 = Integer.parseInt(texto);
                if(num2 != 0){
                    double division = (double) num1 / num2;

                    IO.println(String.format("Resultado = %.2f", division));
                }else{
                    IO.println("No se puede dividir entre cero.");
                }
                break;

            case 5:

                IO.println("Gracias por usar la calculadora.");
                break;
            default:
                IO.println("Opción incorrecta.");
        }

        IO.println("");
    }while(opcion != 5);

}
